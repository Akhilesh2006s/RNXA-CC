# Production Railway API (used on Vercel / non-localhost unless overridden)
NEXT_PUBLIC_API_BASE_URL=https://rnxa-cc-backend-production.up.railway.app/api/v1

# Local backend (use in apps/web/.env while developing)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1

# Force production API while on localhost (optional)
# NEXT_PUBLIC_USE_REMOTE_API=true

# On Vercel: set NEXT_PUBLIC_API_BASE_URL in Project → Environment Variables.
# On Railway backend: set CLIENT_ORIGIN to your Vercel URL + http://localhost:3001
