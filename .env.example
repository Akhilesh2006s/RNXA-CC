# Backend root (either form works — `/api/v1` is auto-appended when missing).
NEXT_PUBLIC_API_BASE_URL=https://founder-os-backend-production-48a7.up.railway.app

# Equivalent explicit URL:
# NEXT_PUBLIC_API_BASE_URL=https://founder-os-backend-production-48a7.up.railway.app/api/v1

# Local backend
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1

# ── Railway backend (required there, not here) ──
# On Railway set CLIENT_ORIGIN to your canonical Vercel URL(s) and CLIENT_ORIGIN_SUFFIXES
# to your Vercel team host (see backend .env.example) or browsers will block credentialed requests.

